{
  "name": "vridik-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Frontend del copiloto legal Vridik (React + Vite + TypeScript). Consume la API FastAPI (auth con 2FA, casos, generación de documentos con JuliX).",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "start": "serve -s dist -l $PORT"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.2",
    "serve": "^14.2.6"
  },
  "devDependencies": {
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.2",
    "typescript": "^5.6.2",
    "vite": "^5.4.8"
  }
}
